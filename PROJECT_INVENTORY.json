  "database": {
    "type": "PostgreSQL",
    "tables": 3,
    "tables_detail": {
      "event_types": {
        "columns": ["id", "title", "description", "duration_minutes", "slug", "color", "created_at", "updated_at"],
        "relationships": ["1:many with availability", "1:many with bookings"],
        "indexes": ["slug (unique)"]
      },
      "availability": {
        "columns": ["id", "event_type_id", "day_of_week", "start_time", "end_time", "timezone", "created_at", "updated_at"],
        "relationships": ["many:1 with event_types"],
        "indexes": ["event_type_id", "day_of_week"]
      },
      "bookings": {
        "columns": ["id", "event_type_id", "booker_name", "booker_email", "booked_date", "booked_time", "booked_datetime", "status", "created_at", "updated_at"],
        "relationships": ["many:1 with event_types"],
        "indexes": ["event_type_id", "booked_date", "booked_datetime"]
      }
    }
  },

